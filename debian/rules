#!/usr/bin/make -f

export DH_VERBOSE = 1
export PYBUILD_NAME=warp-indicator

%:
	dh $@ --with python3 --buildsystem=pybuild

override_dh_auto_build:
	dh_auto_build

override_dh_auto_test:
	# Skip tests for now

override_dh_auto_install:
	dh_auto_install
	install -D -m 755 warp-indicator.py debian/warp-indicator/usr/bin/warp-indicator
	install -D -m 644 warp-indicator.py debian/warp-indicator/usr/lib/python3/dist-packages/warp_indicator/__init__.py

execute_after_dh_installuserbin:
	install -D -m 755 warp-indicator.py debian/warp-indicator/usr/bin/warp-indicator
